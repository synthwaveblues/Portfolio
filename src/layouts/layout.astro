---
import Nav from '../components/ui/Nav';

interface Props {
  title: string;
}

const {title} = Astro.props;
---

<style is:global>
    @import '../styles/global.css';
</style>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>{title}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="Anton Shevchenko — Full-Stack Developer portfolio"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
</head>
<body>
<Nav client:load/>
<slot/>
</body>
</html>